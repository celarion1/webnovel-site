# 이 파일을 복사해서 .env.local 로 저장한 뒤 실제 값을 채우세요.
# .env.local은 .gitignore에 의해 git에 올라가지 않습니다.

# 관리자 로그인 비밀번호 (원하는 값으로 직접 정하세요)
ADMIN_PASSWORD=여기에_원하는_비밀번호

# Vercel 대시보드 > Storage > Upstash Redis 연결 후 발급되는 값
# 이름이 KV_REST_API_* 가 아니라 UPSTASH_REDIS_REST_* 로 되어 있어도 무방합니다.
KV_REST_API_URL=
KV_REST_API_TOKEN=
